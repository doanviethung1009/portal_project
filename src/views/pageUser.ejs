<!DOCTYPE html>
<html>

<head>
    <style>
        table {
            font-family: arial, sans-serif;
            border-collapse: collapse;
            width: 100%;
        }

        td,
        th {
            border: 1px solid #dddddd;
            text-align: left;
            padding: 8px;
        }

        tr:nth-child(even) {
            background-color: #dddddd;
        }
    </style>
</head>

<body>

    <h2>HTML Table</h2>

    <table>

        <tr>
            <th>id</th>
            <th>username</th>
            <th>email</th>
            <th>Country</th>
        </tr>
        <% for(let i=0 ; i < data.length; i++) { %>


            <tr>
                <td>
                    <%= data[i].id %>
                </td>
                <td>
                    <%= data[i].username %>
                </td>
                <td>
                    <%= data[i].email %>
                </td>
                <td>
                    <%= data[i].country || 'Germany' %>
                </td>
                <td>
                    <button onclick="editUser('<%= data[i].id %>')">edit</button>
                    <button onclick="deleteUser('<%= data[i].id %>')">delete</button>
                </td>

            </tr>

            <% } %>
    </table>

</body>
<script>
    function deleteUser(id) {
        if (confirm('Are you sure you want to delete this user?')) {
            fetch(`/v1/api/user/${id}`, {
                method: 'DELETE'
            })
                .then(data => {
                    // alert(data.errMessage);
                    location.reload(); // Refresh the page to update the table
                })
                .catch(err => console.error('Error:', err));
        }
    }

    function editUser(id) {
        alert("Edit function for user ID: " + id);
        // Add edit logic here
    }
</script>

</html>